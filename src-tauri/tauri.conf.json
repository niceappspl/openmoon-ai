{
  "productName": "openMOON",
  "version": "1.0.1",
  "identifier": "com.openmoon.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3333",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/system_prompt.md"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": "entitlements.plist"
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "openMOON",
        "width": 600,
        "height": 140,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "skipTaskbar": false,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["/Applications/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgzQTQyRkU1NzZENTA2RjUKUldUMUJ0VjI1UytrZzV3bmdVcG4xeHlscGlzZFM5RE9xZ2FOb0pWVnpNcDg3eERTSmFsTFU5d1oK",
      "endpoints": [
        "https://github.com/niceappspl/openmoon-ai/releases/latest/download/latest.json"
      ]
    }
  }
}


# OpenAI API Key (required when provider = "openai")
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: local LLM via Ollama (provider = "ollama")
# Defaults if omitted: http://localhost:11434 and model "llama3.1"
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Optional: token for a remote MCP connector referenced as ${REMOTE_MCP_TOKEN} in config.json
# REMOTE_MCP_TOKEN=

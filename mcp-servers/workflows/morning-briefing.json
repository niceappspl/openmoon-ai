    {
      "action": "get_battery_info",
      "params": {},
      "delay": 500
    },
    {
      "action": "show_notification",
      "params": {
        "title": "Good morning!",
        "message": "Your briefing is ready."
      },
      "delay": 500
    }
  ]
}

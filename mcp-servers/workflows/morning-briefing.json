{
  "id": "morning-briefing",
  "name": "Morning Briefing",
  "description": "Check calendar, emails, battery and system status to start your day",
  "icon": "☀️",
  "steps": [
    {
      "action": "list_events",
      "params": { "days": 1 }
    },
    {
      "action": "get_unread_emails",
